# Stackly environment configuration
# Copy to .env and adjust

# HTTP server port
PORT=8890

# ─── API Auth ────────────────────────────────────────────────
# Comma-separated list of valid API keys. Leave empty to disable auth (open API).
# Generate keys with: openssl rand -hex 32
# Example: STACKLY_API_KEYS=sk_live_abc123def456,sk_live_xyz789ghi012
STACKLY_API_KEYS=

# ─── Rate Limit ──────────────────────────────────────────────
# Per-IP requests per minute. 0 = disabled.
STACKLY_RATE_LIMIT=60

# ─── Cache ───────────────────────────────────────────────────
# TTL duration: 24h, 1h, 30m, etc.
CACHE_TTL=24h
# Path to cache JSON file (persists across restarts)
CACHE_PATH=./data/cache.json

# ─── Scanner ─────────────────────────────────────────────────
# Rotate User-Agent per scan (recommended for production)
UA_ROTATE=true

# ─── Chrome (chromedp) ──────────────────────────────────────
# Override chrome binary path. Empty = auto-detect.
# In Docker, set to /headless-shell/bin/headless-shell
CHROME_BIN=

# Proxy (optional) — http://user:pass@host:port or socks5://host:port
PROXY_URL=